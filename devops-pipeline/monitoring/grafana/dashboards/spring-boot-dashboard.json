{
  "uid": "spring-boot-overview",
  "title": "Spring Boot — DevOps Demo",
  "tags": ["spring-boot", "java", "devops-demo"],
  "timezone": "browser",
  "refresh": "15s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job='spring-boot-app'}[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Response Time (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{job='spring-boot-app'}[5m]))",
          "legendFormat": "p99 latency"
        }
      ]
    },
    {
      "id": 3,
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job='spring-boot-app', area='heap'}",
          "legendFormat": "Heap Used"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 4,
      "title": "JVM Threads",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job='spring-boot-app'}",
          "legendFormat": "Live Threads"
        }
      ]
    },
    {
      "id": 5,
      "title": "App Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "process_uptime_seconds{job='spring-boot-app'}",
          "legendFormat": "Uptime (s)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 6,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "process_cpu_usage{job='spring-boot-app'}",
          "legendFormat": "CPU Usage"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      }
    }
  ]
}
